{
  "name": "schedule-app",
  "version": "1.1.0",
  "description": "工程表管理アプリ",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && vite build --config vite.viewer.config.js && copy dist-viewer\\viewer.html dist-viewer\\index.html",
    "build:win": "npm run build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^10.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.company.schedule-app",
    "productName": "工程表管理",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist-installer"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ja-JP"],
      "language": "1041"
    },
    "files": [
      "dist/**/*",
      "dist-viewer/**/*",
      "electron/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-viewer",
        "to": "viewer"
      }
    ]
  }
}
